{
  "hooks": {
    // PostToolUse hooks fire after every Edit or Write tool call.
    // Each script reads the file path from stdin and exits early if it's not in the relevant directory.
    "PostToolUse": [
      {
        // Run go vet + gofmt check immediately after any backend/ file is edited.
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/post-edit-backend-vet.sh\""
          }
        ]
      },
      {
        // Remind Claude to Playwright-verify after any site/ file is edited (excludes public/ and tests/).
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/post-edit-site-check.sh\""
          }
        ]
      }
    ],
    // PreToolUse hooks fire before every Bash tool call.
    "PreToolUse": [
      {
        // Block destructive shell commands (rm -rf, force-push, hard-reset, DDL drops)
        // and require explicit user confirmation before proceeding.
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/pre-bash-block-destructive.sh\""
          }
        ]
      },
      {
        // Run the full CI suite before any git commit; block the commit if CI fails.
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/pre-bash-ci-before-commit.sh\"",
            "timeout": 600,
            "statusMessage": "Running CI before commit..."
          }
        ]
      }
    ],
    // Stop hook fires once after Claude finishes each turn.
    "Stop": [
      {
        // Run the full CI suite at the end of every turn to catch any regressions
        // before the user switches context. Summary written to scripts/out/run-ci.txt.
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/stop-run-ci.sh\"",
            "timeout": 600,
            "statusMessage": "Running CI scripts..."
          }
        ]
      }
    ]
  }
}
